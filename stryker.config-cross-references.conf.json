{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-schema.json",
  "mutate": [
    "src/plugins/norbert-config/domain/references/registry.ts"
  ],
  "testRunner": "vitest",
  "reporters": ["clear-text", "json", "html"],
  "jsonReporter": {
    "fileName": "docs/feature/config-cross-references/deliver/mutation/stryker-report.json"
  },
  "htmlReporter": {
    "fileName": "docs/feature/config-cross-references/deliver/mutation/mutation-report.html"
  },
  "vitest": {
    "configFile": "vitest.mutation.config-cross-references.ts"
  },
  "tempDirName": ".stryker-tmp"
}

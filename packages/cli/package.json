{
  "name": "@norbert/cli",
  "version": "0.1.0",
  "description": "Commander.js CLI for Norbert Observatory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "norbert": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@norbert/config": "workspace:*",
    "@norbert/core": "workspace:*",
    "@norbert/hooks": "workspace:*",
    "@norbert/server": "workspace:*",
    "@norbert/storage": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3"
  }
}

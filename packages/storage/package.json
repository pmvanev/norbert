{
  "name": "@norbert/storage",
  "version": "0.1.0",
  "description": "Storage port and SQLite adapter for Norbert Observatory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json && cp -r src/migrations dist/migrations",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@norbert/core": "workspace:*",
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}

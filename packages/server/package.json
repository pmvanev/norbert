{
  "name": "@norbert/server",
  "version": "0.1.0",
  "description": "Fastify HTTP server, API, and WebSocket for Norbert Observatory",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@norbert/config": "workspace:*",
    "@norbert/core": "workspace:*",
    "@norbert/config-explorer": "workspace:*",
    "@norbert/storage": "workspace:*",
    "fastify": "^5.7.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1"
  }
}

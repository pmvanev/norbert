{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "incremental": true
  },
  "references": [
    { "path": "packages/core" },
    { "path": "packages/config" },
    { "path": "packages/storage" },
    { "path": "packages/server" },
    { "path": "packages/cli" },
    { "path": "packages/dashboard" },
    { "path": "packages/hooks" }
  ],
  "files": []
}

{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-schema.json",
  "mutate": [
    "src/plugins/norbert-usage/domain/metricsAggregator.ts",
    "src/plugins/norbert-usage/domain/gaugeCluster.ts",
    "src/plugins/norbert-usage/domain/dashboard.ts",
    "src/plugins/norbert-usage/hookProcessor.ts"
  ],
  "testRunner": "vitest",
  "reporters": ["clear-text", "json"],
  "jsonReporter": { "fileName": "docs/feature/otel-first-metrics/deliver/mutation/stryker-report.json" },
  "vitest": {
    "configFile": "vitest.mutation.config.ts"
  },
  "tempDirName": ".stryker-tmp"
}
